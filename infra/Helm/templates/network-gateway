apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: gateway-policy
  namespace: pc-gateway
spec:
  podSelector: {}
  policyTypes:
    - Ingress
    - Egress
  ingress:
    - {} # Allow all ingress — this is your public entry point
  egress:
    # DNS
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
    # api-gateway in pc-edge
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: pc-edge
      ports:
        - protocol: TCP
          port: 3000
    # frontend in pc-frontend
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: pc-frontend
      ports:
        - protocol: TCP
          port: 80
    # kgateway control plane communication
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kgateway-system
      ports:
        - protocol: TCP
          port: 9977
        - protocol: TCP
          port: 443